@model IEnumerable<VinhKhanhFood.Admin.Models.FoodLocation>
@{
    ViewData["Title"] = "Dashboard Overview";
    
    // ✅ Fix: Handle null model
    var locations = Model ?? new List<VinhKhanhFood.Admin.Models.FoodLocation>();
    var recentLocations = locations.Take(5);
    
    // ✅ Fix: Tính tỷ lệ chính xác - kiểm tra TẤT CẢ ngôn ngữ
    var total = locations.Count();
    var translated = locations.Count(x => 
        !string.IsNullOrEmpty(x.Name_EN) || 
        !string.IsNullOrEmpty(x.Description_EN) ||
        !string.IsNullOrEmpty(x.Name_KO) ||
        !string.IsNullOrEmpty(x.Description_KO) ||
        !string.IsNullOrEmpty(x.Name_JA) ||
        !string.IsNullOrEmpty(x.Description_JA) ||
        !string.IsNullOrEmpty(x.Name_ZH) ||
        !string.IsNullOrEmpty(x.Description_ZH)
    );
    var translationRate = total > 0 ? (translated * 100 / total) : 0;
    
    // ✅ Fix: Case-insensitive status check
    var onlineCount = locations.Count(x => x.Status?.ToLower() == "online");
}

<div class="p-8" style="font-family: 'Manrope', 'Inter', sans-serif">
    <div class="mb-8">
        <h1 class="text-3xl font-bold text-slate-900 mb-2">Dashboard Overview</h1>
        <div class="flex items-center gap-2 text-sm text-gray-600 font-medium">
            <span>@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</span>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-[10px] font-bold uppercase tracking-widest mb-1">Total POIs</p>
                <h3 class="text-3xl font-black text-slate-900">@total</h3>
            </div>
            <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-600">
                <i data-lucide="store" class="w-6 h-6"></i>
            </div>
        </div>

        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-[10px] font-bold uppercase tracking-widest mb-1">Online POIs</p>
                <h3 class="text-3xl font-black text-slate-900">@onlineCount</h3>
            </div>
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center text-blue-600">
                <i data-lucide="activity" class="w-6 h-6"></i>
            </div>
        </div>

        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-[10px] font-bold uppercase tracking-widest mb-1">Translation Rate</p>
                <h3 class="text-3xl font-black text-slate-900">@translationRate%</h3>
            </div>
            <div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center text-amber-600">
                <i data-lucide="languages" class="w-6 h-6"></i>
            </div>
        </div>

        <div class="bg-white p-6 rounded-3xl shadow-sm border border-gray-100 flex justify-between items-start">
            <div>
                <p class="text-gray-500 text-[10px] font-bold uppercase tracking-widest mb-1">Translated</p>
                <h3 class="text-3xl font-black text-slate-900">@translated/@total</h3>
            </div>
            <div class="w-12 h-12 bg-emerald-50 rounded-xl flex items-center justify-center text-emerald-500">
                <i data-lucide="check-circle" class="w-6 h-6"></i>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 bg-white rounded-3xl border border-gray-100 shadow-sm overflow-hidden">
            <div class="px-8 py-6 border-b border-gray-50 flex justify-between items-center">
                <h3 class="text-lg font-bold text-slate-900">Recently Added Locations</h3>
                <a asp-controller="FoodLocation" asp-action="Index" class="text-sm font-bold text-emerald-800 hover:bg-emerald-50 px-4 py-2 rounded-xl flex items-center gap-2 transition-all">
                    View All <i data-lucide="external-link" class="w-4 h-4"></i>
                </a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-gray-50/50 text-gray-500 text-[10px] font-bold uppercase tracking-wider">
                        <tr>
                            <th class="px-8 py-4">Restaurant Name</th>
                            <th class="px-8 py-4">Status</th>
                            <th class="px-8 py-4">Translation</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                        @if (recentLocations.Any())
                        {
                            @foreach (var item in recentLocations)
                            {
                                <tr class="hover:bg-gray-50/30 transition-colors">
                                    <td class="px-8 py-5 font-bold text-slate-900">@item.Name</td>
                                    <td class="px-8 py-5">
                                        @if (item.Status?.ToLower() == "online")
                                        {
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">
                                                <span class="w-1.5 h-1.5 rounded-full mr-2 bg-emerald-500"></span> Online
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-yellow-50 text-yellow-700 border border-yellow-100">
                                                <span class="w-1.5 h-1.5 rounded-full mr-2 bg-yellow-500"></span> Pending
                                            </span>
                                        }
                                    </td>
                                    <td class="px-8 py-5">
                                        @if (!string.IsNullOrEmpty(item.Name_EN) || !string.IsNullOrEmpty(item.Description_EN))
                                        {
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-100">
                                                <i data-lucide="check" class="w-3 h-3 mr-1"></i> Translated
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-red-50 text-red-700 border border-red-100">
                                                <i data-lucide="x" class="w-3 h-3 mr-1"></i> Not Yet
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="px-8 py-5 text-center text-gray-500">Không có dữ liệu</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="lg:col-span-1 bg-white p-8 rounded-3xl border border-gray-100 shadow-sm">
            <h3 class="text-lg font-bold text-slate-900 mb-6">System Status</h3>
            <div class="space-y-4">
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <span class="text-sm font-semibold text-slate-600">API Connection</span>
                    <span class="text-xs font-bold text-emerald-600 flex items-center gap-1">
                        <i data-lucide="check-circle" class="w-4 h-4"></i> Active
                    </span>
                </div>
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <span class="text-sm font-semibold text-slate-600">Database</span>
                    <span class="text-xs font-bold text-emerald-600 flex items-center gap-1">
                        <i data-lucide="check-circle" class="w-4 h-4"></i> Synced
                    </span>
                </div>
                <div class="flex items-center justify-between p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <span class="text-sm font-semibold text-slate-600">Translation AI</span>
                    <span class="text-xs font-bold text-emerald-600 flex items-center gap-1">
                        <i data-lucide="check-circle" class="w-4 h-4"></i> Ready
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>