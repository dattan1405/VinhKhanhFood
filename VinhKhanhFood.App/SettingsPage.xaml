<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.SettingsPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,50,20,30" Spacing="20">

                <VerticalStackLayout Spacing="5">
                    <Label Text="Settings" FontSize="32" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Vinh Khanh Foodie Configuration" FontSize="14" TextColor="#AAAAAA" />
                </VerticalStackLayout>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="#1E1E1E" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="20">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Audio &amp; Localization" FontSize="18" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Core audio guide settings" FontSize="13" TextColor="#888888" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLanguageTapped" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" 
                                   Text="&#xe894;" 
                                   FontFamily="MaterialIcons" 
                                   FontSize="24" 
                                   VerticalOptions="Center" 
                                   TextColor="#D32F2F" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Language" FontSize="16" FontAttributes="Bold" TextColor="White" />
                                <Label Text="Audio narration language" FontSize="13" TextColor="#888888" />
                            </VerticalStackLayout>
                            <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                <Label x:Name="LblCurrentLanguage" Text="VN Tiếng Việt" TextColor="#AAAAAA" FontSize="14" VerticalOptions="Center"/>
                                <Label Text=">" TextColor="#AAAAAA" FontSize="18" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#2C2C2C" />

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                            <Label Grid.Column="0" 
                                   Text="&#xe425;" 
                                   FontFamily="MaterialIcons" 
                                   FontSize="24" 
                                   VerticalOptions="Center" 
                                   TextColor="#D32F2F" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Speech Speed" FontSize="16" FontAttributes="Bold" TextColor="White" />
                                <Label Text="Adjust narration speed" FontSize="13" TextColor="#888888" />
                            </VerticalStackLayout>
                            <Border Grid.Column="2" BackgroundColor="#D32F2F" StrokeShape="RoundRectangle 8" StrokeThickness="0" Padding="10,5" VerticalOptions="Center">
                                <Label x:Name="LblSpeedValue" Text="1.0x" TextColor="White" FontAttributes="Bold" FontSize="14" />
                            </Border>
                        </Grid>

                        <VerticalStackLayout Spacing="5">
                            <Slider x:Name="SpeedSlider" Minimum="0.5" Maximum="2.0" Value="1.0" MinimumTrackColor="#D32F2F" MaximumTrackColor="#2C2C2C" ThumbColor="White" ValueChanged="OnSpeedSliderValueChanged" />
                            <Grid ColumnDefinitions="*, *, *">
                                <Label Grid.Column="0" Text="0.5x (Slow)" TextColor="#888888" FontSize="11" HorizontalOptions="Start" />
                                <Label Grid.Column="1" Text="1.0x (Normal)" TextColor="#888888" FontSize="11" HorizontalOptions="Center" />
                                <Label Grid.Column="2" Text="2.0x (Fast)" TextColor="#888888" FontSize="11" HorizontalOptions="End" />
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="#1E1E1E" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="20">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="App Preferences" FontSize="18" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Customize your experience" FontSize="13" TextColor="#888888" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15">
                            <Label Grid.Column="0" 
                                   Text="&#xe3a4;" 
                                   FontFamily="MaterialIcons" 
                                   FontSize="24" 
                                   VerticalOptions="Center" 
                                   TextColor="#D32F2F" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="Dark Mode" FontSize="16" FontAttributes="Bold" TextColor="White" />
                                <Label Text="Currently enabled" FontSize="13" TextColor="#888888" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="True" OnColor="#D32F2F" ThumbColor="White" Toggled="OnThemeSwitchToggled" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16" BackgroundColor="#1E1E1E" StrokeThickness="0" Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="About &amp; Account" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="Version Info:" TextColor="#AAAAAA" />
                            <Label Text="v1.0.0 - MVP Release" TextColor="White" FontAttributes="Bold" />
                        </HorizontalStackLayout>
                        <Button Text="Admin Login" BackgroundColor="#D32F2F" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="45" Margin="0,10,0,0"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Grid x:Name="LanguageModal" BackgroundColor="#A0000000" IsVisible="False">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseModalTapped" />
            </Grid.GestureRecognizers>

            <Border VerticalOptions="End" BackgroundColor="#1E1E1E" StrokeShape="RoundRectangle 20,20,0,0" StrokeThickness="0">
                <VerticalStackLayout Padding="20,20,20,40" Spacing="15">

                    <Grid ColumnDefinitions="*, Auto">
                        <VerticalStackLayout Grid.Column="0">
                            <Label Text="Select Language" FontSize="20" FontAttributes="Bold" TextColor="White" />
                            <Label Text="Choose your preferred audio language" FontSize="14" TextColor="#AAAAAA" Margin="0,5,0,15" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="✕" WidthRequest="32" HeightRequest="32" CornerRadius="16" Padding="0" BackgroundColor="#2C2C2C" TextColor="#AAAAAA" FontAttributes="Bold" VerticalOptions="Start" Clicked="OnCloseModalTapped" />
                    </Grid>

                    <Border x:Name="OptVietnamese" BackgroundColor="#33D32F2F" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="15">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer CommandParameter="VN Tiếng Việt" Tapped="OnLanguageSelected" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="VN" TextColor="#AAAAAA" FontSize="16" VerticalOptions="Center" Margin="0,0,10,0"/>
                            <Label Grid.Column="1" Text="Tiếng Việt" TextColor="#D32F2F" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            <Border Grid.Column="2" WidthRequest="20" HeightRequest="20" StrokeShape="RoundRectangle 10" BackgroundColor="#D32F2F" StrokeThickness="0" VerticalOptions="Center">
                                <BoxView WidthRequest="8" HeightRequest="8" Color="White" CornerRadius="4" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="OptEnglish" BackgroundColor="Transparent" StrokeShape="RoundRectangle 12" StrokeThickness="0" Padding="15">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer CommandParameter="GB English" Tapped="OnLanguageSelected" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0" Text="GB" TextColor="#AAAAAA" FontSize="16" VerticalOptions="Center" Margin="0,0,10,0"/>
                            <Label Grid.Column="1" Text="English" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                            <Border Grid.Column="2" WidthRequest="20" HeightRequest="20" StrokeShape="RoundRectangle 10" BackgroundColor="Transparent" Stroke="#AAAAAA" StrokeThickness="2" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Label Text="More languages coming soon in future updates" TextColor="#555555" FontSize="12" HorizontalOptions="Center" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>