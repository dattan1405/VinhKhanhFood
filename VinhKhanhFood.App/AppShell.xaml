<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VinhKhanhFood.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:VinhKhanhFood.App"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    TabBarBackgroundColor="#FFFFFF"
    TabBarTitleColor="#D32F2F"
    TabBarUnselectedColor="#999999">

    <TabBar>
        <Tab Title="Map" Icon="map_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:MainPage}" />
        </Tab>

        <Tab Title="Explore" Icon="explore_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:ExplorePage}" />
        </Tab>

        <Tab Title="Setting" Icon="settings_icon.png">
            <ShellContent ContentTemplate="{DataTemplate local:SettingsPage}" />
        </Tab>
    </TabBar>

</Shell>