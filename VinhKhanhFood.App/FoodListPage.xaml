<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFood.App.FoodListPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">
    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="20,40,20,20">

            <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                <Label Text="📍" FontSize="24" VerticalOptions="Center" />
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Vị trí hiện tại" FontSize="12" TextColor="#888888" />
                    <Label Text="Phố ẩm thực Vĩnh Khánh" FontSize="18" FontAttributes="Bold" TextColor="White" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <Border BackgroundColor="#1C1C1E" Stroke="Transparent" StrokeShape="RoundRectangle 15" HeightRequest="50">
                <HorizontalStackLayout Padding="15,0" Spacing="10" VerticalOptions="Center">
                    <Label Text="🔍" FontSize="18" TextColor="#888888" VerticalOptions="Center" />
                    <Label Text="Tìm quán ốc, món ngon..." TextColor="#666666" VerticalOptions="Center" />
                </HorizontalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="15">
                <Label Text="Khám phá món ngon" FontSize="20" FontAttributes="Bold" TextColor="White" />
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout Spacing="12">
                        <Border BackgroundColor="#D32F2F" Stroke="Transparent" StrokeShape="RoundRectangle 20" Padding="20,12">
                            <Label Text="🐌 Tất cả" TextColor="White" FontAttributes="Bold" />
                        </Border>
                        <Border BackgroundColor="#1C1C1E" Stroke="Transparent" StrokeShape="RoundRectangle 20" Padding="20,12">
                            <Label Text="🦪 Ốc Hương" TextColor="#AAAAAA" FontAttributes="Bold" />
                        </Border>
                        <Border BackgroundColor="#1C1C1E" Stroke="Transparent" StrokeShape="RoundRectangle 20" Padding="20,12">
                            <Label Text="🦀 Cua Ghẹ" TextColor="#AAAAAA" FontAttributes="Bold" />
                        </Border>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="20">
                <HorizontalStackLayout HorizontalOptions="FillAndExpand">
                    <Label Text="Quán nổi bật" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="StartAndExpand" />
                    <Label Text="Xem tất cả" FontSize="14" TextColor="#D32F2F" VerticalOptions="Center" />
                </HorizontalStackLayout>

                <Border BackgroundColor="#1C1C1E" Stroke="Transparent" StrokeShape="RoundRectangle 25" Shadow="{Shadow Brush=Black, Offset='0,5', Radius=10, Opacity=0.4}">
                    <Grid RowDefinitions="180, Auto">
                        <Image Grid.Row="0" Source="dotnet_bot.png" Aspect="AspectFill" />
                        <Grid Grid.Row="1" Padding="20" RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
                            <Label Grid.Row="0" Grid.Column="0" Text="Quán Ốc Oanh" FontSize="18" FontAttributes="Bold" TextColor="White" />
                            <Label Grid.Row="1" Grid.Column="0" Text="⭐ 4.8 • Cách bạn 50m" FontSize="13" TextColor="#AAAAAA" Margin="0,5,0,0" />

                            <Border Grid.RowSpan="2" Grid.Column="1" BackgroundColor="#D32F2F" Stroke="Transparent" StrokeShape="RoundRectangle 25" WidthRequest="50" HeightRequest="50" VerticalOptions="Center" Shadow="{Shadow Brush=#D32F2F, Offset='0,4', Radius=8, Opacity=0.4}">
                                <Label Text="▶️" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontSize="20" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border BackgroundColor="#1C1C1E" Stroke="Transparent" StrokeShape="RoundRectangle 25" Shadow="{Shadow Brush=Black, Offset='0,5', Radius=10, Opacity=0.4}">
                    <Grid RowDefinitions="180, Auto">
                        <Image Grid.Row="0" Source="dotnet_bot.png" Aspect="AspectFill" BackgroundColor="#2C2C2E" />
                        <Grid Grid.Row="1" Padding="20" RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto">
                            <Label Grid.Row="0" Grid.Column="0" Text="Ốc Nhớ Sài Gòn" FontSize="18" FontAttributes="Bold" TextColor="White" />
                            <Label Grid.Row="1" Grid.Column="0" Text="⭐ 4.5 • Cách bạn 120m" FontSize="13" TextColor="#AAAAAA" Margin="0,5,0,0" />

                            <Border Grid.RowSpan="2" Grid.Column="1" BackgroundColor="#D32F2F" Stroke="Transparent" StrokeShape="RoundRectangle 25" WidthRequest="50" HeightRequest="50" VerticalOptions="Center" Shadow="{Shadow Brush=#D32F2F, Offset='0,4', Radius=8, Opacity=0.4}">
                                <Label Text="▶️" HorizontalOptions="Center" VerticalOptions="Center" TextColor="White" FontSize="20" />
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>