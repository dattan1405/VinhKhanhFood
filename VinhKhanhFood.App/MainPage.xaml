<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="VinhKhanhFood.App.MainPage"
             Shell.NavBarIsVisible="False">

    <Grid>
        <maps:Map x:Name="vinhKhanhMap" IsShowingUser="True" />

        <Border VerticalOptions="Start" Margin="20,50,20,0" Padding="15,5" 
                BackgroundColor="White" StrokeShape="RoundRectangle 25" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.15" />
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Image Source="search_icon.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                <Entry Grid.Column="1" Placeholder="Tìm kiếm địa điểm..." BackgroundColor="Transparent" Margin="10,0"/>
                <Image Source="filter_icon.png" Grid.Column="2" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
            </Grid>
        </Border>

        <Border x:Name="FoodBottomSheet" IsVisible="False" VerticalOptions="End" Margin="15,0,15,30" 
                Padding="15" BackgroundColor="White" StrokeShape="RoundRectangle 20" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="20" Opacity="0.2" />
            </Border.Shadow>
            <Grid ColumnDefinitions="100, *" ColumnSpacing="15">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="100" />
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="#1A1A1A" />
                    <Label Text="{Binding Description}" FontSize="13" TextColor="#666666" MaxLines="2" LineBreakMode="TailTruncation" />
                    <Button Text="Xem Chi Tiết" Clicked="OnViewDetailsClicked" 
                            BackgroundColor="#D32F2F" TextColor="White" 
                            CornerRadius="8" HeightRequest="36" Margin="0,8,0,0" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>