<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="VinhKhanhFood.App.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <Grid>
        <maps:Map x:Name="vinhKhanhMap" IsShowingUser="True" MapType="Street" />

        <VerticalStackLayout VerticalOptions="Start" Padding="0,50,0,0" InputTransparent="True">
            <Border BackgroundColor="#CC121212" StrokeShape="RoundRectangle 12" StrokeThickness="0" Margin="20,0,20,10" Padding="15,10">
                <HorizontalStackLayout>
                    <Label Text="Discover " FontSize="26" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Vinh Khanh" FontSize="26" FontAttributes="Bold" TextColor="#D32F2F" />
                </HorizontalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 12" BackgroundColor="#E6212121" StrokeThickness="0" Margin="20,0,20,15" Padding="15,5" InputTransparent="False">
                <Grid ColumnDefinitions="Auto, *">
                    <Image Source="search_icon.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                    <Entry Grid.Column="1" Placeholder="Search places..." TextColor="White" PlaceholderColor="#888888" BackgroundColor="Transparent" Margin="10,0"/>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <Border x:Name="FoodBottomSheet" 
                BackgroundColor="#1E1E1E" 
                StrokeShape="RoundRectangle 20,20,0,0" 
                VerticalOptions="End" 
                IsVisible="False" 
                StrokeThickness="0">
            <VerticalStackLayout Spacing="15" Padding="20">

                <Border StrokeShape="RoundRectangle 3" BackgroundColor="#CCFFFFFF" WidthRequest="50" HeightRequest="6" HorizontalOptions="Center" StrokeThickness="0"/>

                <Grid ColumnDefinitions="Auto, *">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="0" WidthRequest="100" HeightRequest="100">
                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                    </Border>

                    <Button Text="✕"
                            Grid.Column="1"
                            HorizontalOptions="End"
                            VerticalOptions="Start"
                            WidthRequest="32"
                            HeightRequest="32"
                            CornerRadius="16"
                            Padding="0"
                            FontSize="15"
                            FontAttributes="Bold"
                            TextColor="#AAAAAA"
                            BackgroundColor="#2C2C2C"
                            Clicked="OnCloseBottomSheetClicked"/>

                    <VerticalStackLayout Grid.Column="1" Padding="15,0,30,0" Spacing="5">
                        <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="⭐" FontSize="12" />
                            <Label Text="4.8" TextColor="#FFC107" FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label Text="•" TextColor="#AAAAAA" Margin="5,0"/>
                            <Label Text="150m away" TextColor="#AAAAAA" FontSize="13" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Text="{Binding Description}" TextColor="#AAAAAA" FontSize="14" MaxLines="2" LineBreakMode="TailTruncation" Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Grid>

                <Button Text="View Details" 
                        BackgroundColor="#D32F2F" 
                        TextColor="White" 
                        CornerRadius="8" 
                        HeightRequest="50" 
                        FontAttributes="Bold" 
                        Margin="0,10,0,0"
                        Clicked="OnViewDetailsClicked"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>