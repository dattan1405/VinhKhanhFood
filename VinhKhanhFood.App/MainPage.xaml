<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             x:Class="VinhKhanhFood.App.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#121212">

    <Grid>
        <maps:Map x:Name="vinhKhanhMap" IsShowingUser="True" MapType="Street" />

        <VerticalStackLayout VerticalOptions="Start" Padding="0,50,0,0" InputTransparent="True">
            <Border StrokeShape="RoundRectangle 25" 
                    BackgroundColor="#F21E1E1E" 
                    StrokeThickness="0" 
                    Margin="20,10" 
                    Padding="15,2" 
                    HeightRequest="50"
                    InputTransparent="False"
                    Shadow="{Shadow Brush=Black, Offset='0,5', Radius=10, Opacity=0.3}">
                <Grid ColumnDefinitions="Auto, *">
                    <Label Text="🔍" FontSize="16" VerticalOptions="Center" Margin="5,0,10,0"/>
                    <Entry Grid.Column="1" 
                           Placeholder="Search street food..." 
                           TextColor="White" 
                           PlaceholderColor="#888888" 
                           BackgroundColor="Transparent" 
                           FontSize="15"
                           VerticalOptions="Center"/>
                </Grid>
            </Border>
        </VerticalStackLayout>

        <Border x:Name="FoodBottomSheet" 
                BackgroundColor="#1E1E1E" 
                StrokeShape="RoundRectangle 20,20,0,0" 
                VerticalOptions="End" 
                IsVisible="False" 
                StrokeThickness="0"
                Shadow="{Shadow Brush=Black, Offset='0,-5', Radius=15, Opacity=0.4}">
            <VerticalStackLayout Spacing="15" Padding="20">
                <Border StrokeShape="RoundRectangle 3" BackgroundColor="#CCFFFFFF" WidthRequest="50" HeightRequest="6" HorizontalOptions="Center" StrokeThickness="0"/>
                <Grid ColumnDefinitions="Auto, *">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 12" StrokeThickness="0" WidthRequest="100" HeightRequest="100">
                        <Image Source="{Binding ImageUrl}" Aspect="AspectFill"/>
                    </Border>
                    <Button Text="✕" Grid.Column="1" HorizontalOptions="End" VerticalOptions="Start" WidthRequest="32" HeightRequest="32" CornerRadius="16" Padding="0" BackgroundColor="#2C2C2C" TextColor="#AAAAAA" Clicked="OnCloseBottomSheetClicked"/>
                    <VerticalStackLayout Grid.Column="1" Padding="15,0,30,0" Spacing="5">
                        <Label Text="{Binding DisplayName}" FontSize="18" FontAttributes="Bold" TextColor="White" />
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="⭐" FontSize="12" />
                            <Label Text="4.8" TextColor="#FFC107" FontSize="13" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Label Text="•" TextColor="#AAAAAA" Margin="5,0"/>
                            <Label Text="150m away" TextColor="#AAAAAA" FontSize="13" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Label Text="{Binding DisplayDescription}" TextColor="#AAAAAA" FontSize="14" MaxLines="2" LineBreakMode="TailTruncation" Margin="0,5,0,0"/>
                    </VerticalStackLayout>
                </Grid>
                <Button Text="View Details" BackgroundColor="#D32F2F" TextColor="White" CornerRadius="8" HeightRequest="50" FontAttributes="Bold" Clicked="OnViewDetailsClicked"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>